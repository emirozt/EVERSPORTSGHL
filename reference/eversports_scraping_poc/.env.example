# ── PER-TENANT (written by admin-cli, stored in tenants/{id}/.env) ──────────

# GoHighLevel V2 API credentials
GHL_API_KEY=
GHL_LOCATION_ID=
GHL_API_BASE=https://services.leadconnectorhq.com

# GHL contact tagging options
GHL_TAG_SOURCE=eversports
GHL_TAG_CLASS_NAME=true
GHL_TAG_CUSTOMER_GROUP=true

# Eversports scraper target
EVERSPORTS_BASE_URL=https://app.eversportsmanager.com

# Sync behaviour
SYNC_DAYS_BACK=1
CRON_SCHEDULE=0 6-22 * * 1-6
WARN_DAYS_BEFORE_EXPIRY=5

# Filesystem paths (relative to tenant dir)
STATE_FILE=./data/synced.json
CSV_BACKUP=./data/bookings.csv
LOG_FILE=./logs/sync.log
LOG_LEVEL=info

# Playwright
HEADLESS=true

# Webhook URL to POST when session is expiring or expired
NOTIFY_WEBHOOK_URL=

# ── PORTAL-LEVEL (root .env) ─────────────────────────────────────────────────

PORTAL_PORT=3000
AGENCY_NAME=Sync Portal
PORTAL_URL=
