# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ghlconnector

# ── Secrets manager ───────────────────────────────────────────────────────────
SECRETS_PROVIDER=env        # env | doppler | aws-secrets-manager
DOPPLER_TOKEN=

# ── Eversports scraper ────────────────────────────────────────────────────────
# Informational / fallback — NOT used for automated login in v1 (TOTP 2FA blocks
# that path). Eversports admin URL: https://app.eversportsmanager.com
EVERSPORTS_EMAIL=
EVERSPORTS_PASSWORD=
# Cookie-Editor JSON export for the test/dev account.
# Paste the full JSON array here and run:
#   python scripts/import_cookies.py --location-id <UUID> --cookies-json "$EVERSPORTS_TEST_COOKIE_JSON"
# Cookies expire ~30 days after export; re-export when scraper reports 'session expired'.
EVERSPORTS_TEST_COOKIE_JSON=

# ── GoHighLevel ───────────────────────────────────────────────────────────────
GHL_OAUTH_CLIENT_ID=
GHL_OAUTH_CLIENT_SECRET=
GHL_WEBHOOK_SIGNING_SECRET=
GHL_REDIRECT_URI=https://your-domain.com/oauth/callback

# ── AI ────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
AI_DEFAULT_MODEL=claude-sonnet-4-6
AI_CLASSIFIER_MODEL=claude-haiku-4-5

# ── Observability ─────────────────────────────────────────────────────────────
SENTRY_DSN=
PROMETHEUS_PUSHGATEWAY=
SLACK_ALERT_WEBHOOK=

# ── Operations ────────────────────────────────────────────────────────────────
ENV=development             # development | staging | production
LOG_LEVEL=INFO
FOUNDATION_API_SIGNING_SECRET=

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
PYTHONUNBUFFERED=1
