# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ghlconnector

# ── Secrets manager ───────────────────────────────────────────────────────────
SECRETS_PROVIDER=env        # env | doppler | aws-secrets-manager
DOPPLER_TOKEN=

# ── GoHighLevel ───────────────────────────────────────────────────────────────
GHL_OAUTH_CLIENT_ID=
GHL_OAUTH_CLIENT_SECRET=
GHL_WEBHOOK_SIGNING_SECRET=
GHL_REDIRECT_URI=https://your-domain.com/oauth/callback

# ── AI ────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
AI_DEFAULT_MODEL=claude-sonnet-4-6
AI_CLASSIFIER_MODEL=claude-haiku-4-5

# ── Observability ─────────────────────────────────────────────────────────────
SENTRY_DSN=
PROMETHEUS_PUSHGATEWAY=
SLACK_ALERT_WEBHOOK=

# ── Operations ────────────────────────────────────────────────────────────────
ENV=development             # development | staging | production
LOG_LEVEL=INFO
FOUNDATION_API_SIGNING_SECRET=

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
PYTHONUNBUFFERED=1
